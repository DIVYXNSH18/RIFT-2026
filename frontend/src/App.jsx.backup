                marginTop: 12,
                fontFamily: "'DM Sans', sans-serif",
                fontSize: 13,
                color: "rgba(255,255,255,0.55)",
              }}
            >
              Powered by AI — built for speed
            </div>
          </div>
          {/* Dots */}
          <div
            style={{
              position: "absolute",
              bottom: 24,
              left: "50%",
              transform: "translateX(-50%)",
              display: "flex",
              gap: 6,
            }}
          >
            {[0, 1, 2].map((i) => (
              <div
                key={i}
                style={{
                  width: i === 0 ? 20 : 7,
                  height: 7,
                  borderRadius: 4,
                  background: i === 0 ? "#fff" : "rgba(255,255,255,0.35)",
                }}
              />
            ))}
          </div>
        </div>

        {/* Right form */}
        <div style={{ flex: 1, paddingTop: 12 }}>
          <h1
            style={{
              fontFamily: "'Playfair Display', serif",
              fontSize: 40,
              fontWeight: 700,
              color: "#111110",
              lineHeight: 1.2,
              marginBottom: 10,
            }}
          >
            Create a Run
          </h1>
          <p
            style={{
              fontFamily: "'DM Sans', sans-serif",
              fontSize: 15,
              color: "#6b6860",
              marginBottom: 32,
            }}
          >
            Analyze your repository and auto-fix CI/CD failures.
          </p>

          <div
            style={{
              display: "flex",
              flexDirection: "column",
              gap: 16,
              marginBottom: 24,
            }}
          >
            {[
              {
                key: "repoUrl",
                label: "GitHub Repository URL",
                placeholder: "https://github.com/org/repo",
              },
              {
                key: "teamName",
                label: "Team Name",
                placeholder: "e.g. RIFT ORGANISERS",
              },
              {
                key: "leaderName",
                label: "Team Leader Name",
                placeholder: "e.g. Saiyam Kumar",
              },
            ].map(({ key, label, placeholder }) => (
              <div key={key}>
                <label
                  style={{
                    display: "block",
                    fontFamily: "'DM Sans', sans-serif",
                    fontSize: 13,
                    fontWeight: 500,
                    color: "#2a2926",
                    marginBottom: 6,
                  }}
                >
                  {label}
                </label>
                <input
                  type="text"
                  placeholder={placeholder}
                  value={formData[key]}
                  onChange={(e) =>
                    setFormData((p) => ({ ...p, [key]: e.target.value }))
                  }
                  onFocus={() => setFocused(key)}
                  onBlur={() => setFocused("")}
                  style={inputStyle(key)}
                />
              </div>
            ))}
          </div>

          {/* Run Agent button */}
          <button
            onClick={onRun}
            disabled={isLoading}
            onMouseEnter={() => setHoverBtn("run")}
            onMouseLeave={() => setHoverBtn("")}
            style={{
              width: "100%",
              height: 54,
              background: "#2a2926",
              color: "#fff",
              borderRadius: 10,
              fontFamily: isLoading
                ? "'DM Mono', monospace"
                : "'Playfair Display', serif",
              fontSize: 16,
              fontWeight: 700,
              display: "flex",
              alignItems: "center",
              justifyContent: "center",
              gap: 10,
              transform:
                hoverBtn === "run" && !isLoading
                  ? "translateY(-1px)"
                  : "translateY(0)",
              boxShadow:
                hoverBtn === "run" && !isLoading
                  ? "0 8px 24px rgba(0,0,0,0.2)"
                  : "0 4px 12px rgba(0,0,0,0.12)",
              transition: "all 0.2s ease",
              opacity: isLoading ? 0.85 : 1,
            }}
          >
            {isLoading && (
              <span
                style={{
                  width: 18,
                  height: 18,
                  border: "2.5px solid rgba(255,255,255,0.3)",
                  borderTopColor: "#fff",
                  borderRadius: "50%",
                  animation: "spin 0.7s linear infinite",
                  display: "inline-block",
                }}
              />
            )}
            {isLoading ? "Analyzing…" : "Run Agent"}
          </button>

          {/* Loading steps */}
          {isLoading && (
            <div
              style={{
                marginTop: 24,
                padding: 20,
                background: "#f8f8f6",
                borderRadius: 12,
                border: "1px solid #e8e7e3",
              }}
            >
              {loadingSteps.map((step, i) => {
                const done = i < loadingStep;
                const active = i === loadingStep;
                return (
                  <div
                    key={step}
                    style={{
                      display: "flex",
                      alignItems: "center",
                      gap: 12,
                      padding: "8px 0",
                      opacity: i > loadingStep ? 0.4 : 1,
                      transition: "opacity 0.3s",
                    }}
                  >
                    <div
                      style={{
                        width: 22,
                        height: 22,
                        borderRadius: "50%",
                        display: "flex",
                        alignItems: "center",
                        justifyContent: "center",
                        background: done
                          ? "#e8f5ef"
                          : active
                            ? "#2a2926"
                            : "#e8e7e3",
                        animation: active ? "pulse 1s ease infinite" : "none",
                        flexShrink: 0,
                      }}
                    >
                      {done ? (
                        <CheckIcon />
                      ) : active ? (
                        <span
                          style={{
                            width: 8,
                            height: 8,
                            background: "#fff",
                            borderRadius: "50%",
                            display: "block",
                          }}
                        />
                      ) : null}
                    </div>
                    <span
                      style={{
                        fontFamily: "'DM Sans', sans-serif",
                        fontSize: 14,
                        fontWeight: active ? 600 : 400,
                        color: done
                          ? "#14784a"
                          : active
                            ? "#111110"
                            : "#6b6860",
                      }}
                    >
                      {done ? "✓ " : ""}
                      {step}
                    </span>
                  </div>
                );
              })}
            </div>
          )}

          {/* Divider */}
          <div
            style={{
              display: "flex",
              alignItems: "center",
              gap: 12,
              margin: "24px 0",
            }}
          >
            <div style={{ flex: 1, height: 1, background: "#e8e7e3" }} />
            <span
              style={{
                fontFamily: "'DM Sans', sans-serif",
                fontSize: 12,
                color: "#c5c3bc",
                whiteSpace: "nowrap",
              }}
            >
              or configure manually
            </span>
            <div style={{ flex: 1, height: 1, background: "#e8e7e3" }} />
          </div>
          <div style={{ display: "flex", gap: 12 }}>
            {[
              [
                "Load Sample Data",
                () =>
                  setFormData({
                    repoUrl: mockResults.repoUrl,
                    teamName: mockResults.teamName,
                    leaderName: mockResults.leaderName,
                  }),
              ],
              [
                "Reset Form",
                () =>
                  setFormData({ repoUrl: "", teamName: "", leaderName: "" }),
              ],
            ].map(([label, action]) => (
              <button
                key={label}
                onClick={action}
                style={{
                  flex: 1,
                  height: 46,
                  background: "transparent",
                  border: "1.5px solid #e8e7e3",
                  borderRadius: 10,
                  fontFamily: "'DM Sans', sans-serif",
                  fontSize: 14,
                  color: "#2a2926",
                  transition: "border-color 0.2s ease, background 0.2s ease",
                }}
                onMouseEnter={(e) => {
                  e.currentTarget.style.borderColor = "#2a2926";
                  e.currentTarget.style.background = "#f2f1ee";
                }}
                onMouseLeave={(e) => {
                  e.currentTarget.style.borderColor = "#e8e7e3";
                  e.currentTarget.style.background = "transparent";
                }}
              >
                {label}
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  );
};

/* ─── PAGE 2: RESULTS ────────────────────────────────────────────────── */
const ResultsPage = ({ results }) => {
  const [visibleRows, setVisibleRows] = useState(0);
  useEffect(() => {
    let i = 0;
    const t = setInterval(() => {
      i++;
      setVisibleRows(i);
      if (i >= results.fixes.length) clearInterval(t);
    }, 60);
    return () => clearInterval(t);
  }, []);

  return (
    <div
      className="page-enter"
      style={{ maxWidth: 1200, margin: "0 auto", padding: "96px 48px 64px" }}
    >
      {/* Summary Card */}
      <div
        style={{
          background: "#fff",
          borderRadius: 20,
          boxShadow: "0 12px 40px rgba(0,0,0,0.10)",
          padding: 40,
          marginBottom: 32,
        }}
      >
        <div
          style={{
            display: "flex",
            justifyContent: "space-between",
            alignItems: "flex-start",
            marginBottom: 28,
            flexWrap: "wrap",
            gap: 16,
          }}
        >
          <div>
            <div
              style={{
                fontFamily: "'DM Mono', monospace",
                fontSize: 13,
                color: "#2a2926",
                marginBottom: 8,
                maxWidth: 380,
                overflow: "hidden",
                textOverflow: "ellipsis",
                whiteSpace: "nowrap",
              }}
            >
              {results.repoUrl}
            </div>
            <div
              style={{
                display: "flex",
                gap: 10,
                flexWrap: "wrap",
                alignItems: "center",
              }}
            >
              <span
                style={{
                  background: "#f2f1ee",
                  border: "1px solid #e8e7e3",
                  borderRadius: 20,
                  padding: "4px 14px",
                  fontFamily: "'DM Sans', sans-serif",
                  fontSize: 12,
                  fontWeight: 600,
                  color: "#2a2926",
                }}
              >
                {results.teamName}
              </span>
              <span
                style={{
                  fontFamily: "'DM Sans', sans-serif",
                  fontSize: 13,
                  color: "#6b6860",
                }}
              >
                Lead: <strong>{results.leaderName}</strong>
              </span>
            </div>
          </div>
          <StatusBadge status={results.status} />
        </div>
        {/* Metrics */}
        <div
          className="metrics-row"
          style={{
            display: "flex",
            borderTop: "1px solid #e8e7e3",
            paddingTop: 24,
          }}
        >
          {[
            {
              icon: "🔗",
              label: "Branch Created",
              value: results.branchName,
              color: "#2a2926",
              mono: true,
            },
            {
              icon: "⚠️",
              label: "Failures Detected",
              value: results.failuresDetected,
              color: "#c0392b",
            },
            {
              icon: "✅",
              label: "Fixes Applied",
              value: results.fixesApplied,
              color: "#14784a",
            },
            {
              icon: "⏱",
              label: "Time Taken",
              value: results.timeTaken,
              color: "#c17d11",
            },
          ].map(({ icon, label, value, color, mono }, i, arr) => (
            <div
              key={label}
              style={{
                flex: 1,
                padding: "0 24px",
                borderRight: i < arr.length - 1 ? "1px solid #e8e7e3" : "none",
                textAlign: "center",
              }}
            >
              <div style={{ fontSize: 20, marginBottom: 6 }}>{icon}</div>
              <div
                style={{
                  fontFamily: "'DM Sans', sans-serif",
                  fontSize: 11,
                  color: "#6b6860",
                  textTransform: "uppercase",
                  letterSpacing: "0.08em",
                  marginBottom: 6,
                }}
              >
                {label}
              </div>
              <div
                style={{
                  fontFamily: mono
                    ? "'DM Mono', monospace"
                    : "'DM Sans', sans-serif",
                  fontSize: mono ? 11 : 22,
                  fontWeight: 700,
                  color,
                  overflow: "hidden",
                  textOverflow: "ellipsis",
                  whiteSpace: "nowrap",
                }}
              >
                {value}
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* Fixes Table */}
      <div
        style={{
          background: "#fff",
          borderRadius: 20,
          boxShadow: "0 4px 16px rgba(0,0,0,0.08)",
          overflow: "hidden",
        }}
      >
        <div style={{ padding: "32px 40px 20px" }}>
          <h2
            style={{
              fontFamily: "'Playfair Display', serif",
              fontSize: 24,
              fontWeight: 700,
              color: "#111110",
              marginBottom: 4,
            }}
          >
            Fixes Applied
          </h2>
          <p
            style={{
              fontFamily: "'DM Sans', sans-serif",
              fontSize: 14,
              color: "#6b6860",
            }}
          >
            All changes committed to branch
          </p>
        </div>
        <div style={{ overflowX: "auto" }}>
          <table>
            <thead>
              <tr style={{ background: "#f2f1ee" }}>
                {["File", "Bug Type", "Line", "Commit Message", "Status"].map(
                  (h) => (
                    <th
                      key={h}
                      style={{
                        fontFamily: "'DM Sans', sans-serif",
                        fontSize: 11,
                        fontWeight: 600,
                        color: "#6b6860",
                        textTransform: "uppercase",
                        letterSpacing: "0.1em",
                        borderBottom: "1px solid #e8e7e3",
                      }}
                    >
                      {h}
                    </th>
                  ),
                )}
              </tr>
            </thead>
            <tbody>
              {results.fixes.map((fix, i) => (
                <tr
                  key={i}
                  className={i < visibleRows ? "row-animate" : ""}
                  style={{
                    animationDelay: `${i * 50}ms`,
                    borderBottom: "1px solid #f2f1ee",
                    transition: "background 0.15s ease",
                    cursor: "default",
                    opacity: i < visibleRows ? 1 : 0,
                  }}
                  onMouseEnter={(e) => {
                    e.currentTarget.style.background = "#f8f8f6";
                  }}
                  onMouseLeave={(e) => {
                    e.currentTarget.style.background = "transparent";
                  }}
                >
                  <td
                    style={{
                      fontFamily: "'DM Mono', monospace",
                      fontSize: 12,
                      color: "#6b6860",
                      maxWidth: 180,
                      overflow: "hidden",
                      textOverflow: "ellipsis",
                      whiteSpace: "nowrap",
                    }}
                  >
                    {fix.file}
                  </td>
                  <td>
                    <BugBadge type={fix.bugType} />
                  </td>
                  <td
                    style={{
                      fontFamily: "'DM Mono', monospace",
                      fontSize: 13,
                      color: "#2a2926",
                    }}
                  >
                    {fix.line}
                  </td>
                  <td
                    style={{
                      fontFamily: "'DM Sans', sans-serif",
                      fontSize: 13,
                      fontStyle: "italic",
                      color: "#6b6860",
                      maxWidth: 240,
                      overflow: "hidden",
                      textOverflow: "ellipsis",
                      whiteSpace: "nowrap",
                    }}
                    title={fix.commit}
                  >
                    {fix.commit}
                  </td>
                  <td
                    style={{
                      fontFamily: "'DM Sans', sans-serif",
                      fontSize: 13,
                      fontWeight: 700,
                      color: fix.status === "Fixed" ? "#14784a" : "#c0392b",
                    }}
                  >
                    {fix.status === "Fixed" ? "✓ Fixed" : "✗ Failed"}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
};

export default function App() {
  const [showLanding, setShowLanding] = useState(true);
  const [activePage, setActivePage] = useState("analyze");
  const [formData, setFormData] = useState({
    repoUrl: "",
    teamName: "",
    leaderName: "",
  });
  const [isLoading, setIsLoading] = useState(false);
  const [loadingStep, setLoadingStep] = useState(0);
  const [hasResults, setHasResults] = useState(false);

  if (showLanding) {
    return (
      <div
        style={{
          minHeight: "100vh",
          background: "linear-gradient(135deg, #1a1a2e 0%, #16213e 40%, #0f3460 70%, #533483 100%)",
          backgroundSize: "400% 400%",
          animation: "gradientShift 8s ease infinite",
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
          position: "relative",
          overflow: "hidden",
        }}
      >
        <GlobalStyles />
        {/* Animated lighting orbs */}
        <div
          style={{
            position: "absolute",
            top: "20%",
            left: "10%",
            width: 400,
            height: 400,
            borderRadius: "50%",
            background: "radial-gradient(circle, rgba(83,52,131,0.4) 0%, transparent 70%)",
            filter: "blur(60px)",
            animation: "float 20s ease-in-out infinite",
          }}
        />
        <div
          style={{
            position: "absolute",
            bottom: "15%",
            right: "15%",
            width: 500,
            height: 500,
            borderRadius: "50%",
            background: "radial-gradient(circle, rgba(15,52,96,0.5) 0%, transparent 70%)",
            filter: "blur(80px)",
            animation: "float2 25s ease-in-out infinite",
          }}
        />
        <div
          style={{
            position: "absolute",
            top: "50%",
            right: "20%",
            width: 350,
            height: 350,
            borderRadius: "50%",
            background: "radial-gradient(circle, rgba(22,33,62,0.6) 0%, transparent 70%)",
            filter: "blur(70px)",
            animation: "float 18s ease-in-out infinite 5s",
          }}
        />
        {/* Decorative grid */}
        <div
          style={{
            position: "absolute",
            inset: 0,
            backgroundImage:
              "linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px)",
            backgroundSize: "60px 60px",
          }}
        />
        {/* Content */}
        <div
          className="page-enter"
          style={{
            textAlign: "center",
            zIndex: 1,
            maxWidth: 700,
            padding: "0 32px",
          }}
        >
          <div
            style={{
              width: 80,
              height: 80,
              background: "rgba(255,255,255,0.15)",
              borderRadius: 20,
              display: "flex",
              alignItems: "center",
              justifyContent: "center",
              margin: "0 auto 32px",
              backdropFilter: "blur(10px)",
            }}
          >
            <PipelineIcon size={40} />
          </div>
          <h1
            style={{
              fontFamily: "'Bloody Feast', 'Creepster', cursive",
              fontSize: 80,
              fontWeight: 400,
              color: "#fff",
              lineHeight: 1.2,
              marginBottom: 16,
              textShadow: "0 0 20px rgba(255,0,0,0.3), 0 0 40px rgba(255,0,0,0.2)",
              letterSpacing: "0.05em",
            }}
          >
            Monster
          </h1>
          <p
            style={{
              fontFamily: "'DM Sans', sans-serif",
              fontSize: 20,
              color: "rgba(255,255,255,0.8)",
              marginBottom: 12,
            }}
          >
            Intelligent CI/CD Pipeline AI Agent
          </p>
          <p
            style={{
              fontFamily: "'DM Sans', sans-serif",
              fontSize: 15,
              color: "rgba(255,255,255,0.5)",
              marginBottom: 48,
            }}
          >
            Automatically detect and fix pipeline failures with AI-powered analysis
          </p>
          <button
            onClick={() => setShowLanding(false)}
            style={{
              padding: "16px 48px",
              background: "rgba(255,255,255,0.15)",
              color: "#fff",
              borderRadius: 12,
              fontFamily: "'Playfair Display', serif",
              fontSize: 18,
              fontWeight: 700,
              border: "1px solid rgba(255,255,255,0.3)",
              cursor: "pointer",
              transition: "all 0.3s ease",
              boxShadow: "0 8px 32px rgba(0,0,0,0.3)",
              backdropFilter: "blur(10px)",
              WebkitBackdropFilter: "blur(10px)",
            }}
            onMouseEnter={(e) => {
              e.currentTarget.style.transform = "translateY(-2px)";
              e.currentTarget.style.background = "rgba(255,255,255,0.25)";
              e.currentTarget.style.boxShadow = "0 12px 40px rgba(0,0,0,0.4)";
            }}
            onMouseLeave={(e) => {
              e.currentTarget.style.transform = "translateY(0)";
              e.currentTarget.style.background = "rgba(255,255,255,0.15)";
              e.currentTarget.style.boxShadow = "0 8px 32px rgba(0,0,0,0.3)";
            }}
          >
            Proceed to Dashboard →
          </button>
          <div
            style={{
              marginTop: 48,
              fontFamily: "'DM Sans', sans-serif",
              fontSize: 13,
              color: "rgba(255,255,255,0.4)",
            }}
          >
            Team Jigyasa
          </div>
        </div>
      </div>
    );
  }

  const handleRun = useCallback(() => {
    setIsLoading(true);
    setLoadingStep(0);
    let step = 0;
    const interval = setInterval(() => {
      step++;
      setLoadingStep(step);
      if (step >= 4) {
        clearInterval(interval);
        setTimeout(() => {
          setIsLoading(false);
          setHasResults(true);
          setActivePage("results");
        }, 400);
      }
    }, 900);
  }, []);

  const handleTabClick = (tab) => {
    if (
      (tab === "results" || tab === "score" || tab === "timeline") &&
      !hasResults
    ) {
      setActivePage(tab);
    } else {
      setActivePage(tab);
    }
  };

  const renderPage = () => {
    if (
      (activePage === "results" ||
        activePage === "score" ||
        activePage === "timeline") &&
      !hasResults
    ) {
      return <EmptyState onGoAnalyze={() => setActivePage("analyze")} />;
    }
    switch (activePage) {
      case "analyze":
        return (
          <AnalyzePage
            formData={formData}
            setFormData={setFormData}
            isLoading={isLoading}
            loadingStep={loadingStep}
            onRun={handleRun}
          />
        );
      case "results":
        return <ResultsPage results={mockResults} />;
      case "score":
        return <ScorePage score={mockResults.score} />;
      case "timeline":
        return <TimelinePage timeline={mockResults.timeline} />;
      default:
        return null;
    }
  };

  return (
    <div style={{ minHeight: "100vh", background: "#f8f8f6" }}>
      <GlobalStyles />
      <Navbar activePage={activePage} setActivePage={handleTabClick} />
      <main>{renderPage()}</main>
    </div>
  );
}

/* ─── PAGE 3: SCORE ──────────────────────────────────────────────────── */
function DonutChart({ base, bonus, penalty, total }) {
  const r = 80,
    cx = 100,
    cy = 100,
    circ = 2 * Math.PI * r;
  const baseArc = (base / 100) * circ;
  const bonusArc = (bonus / 100) * circ;
  const penaltyArc = (Math.abs(penalty) / 100) * circ;
  return (
    <svg width="200" height="200" viewBox="0 0 200 200">
      <circle
        cx={cx}
        cy={cy}
        r={r}
        fill="none"
        stroke="#e8e7e3"
        strokeWidth="20"
      />
      <circle
        cx={cx}
        cy={cy}
        r={r}
        fill="none"
        stroke="#1e3a5f"
        strokeWidth="20"
        strokeDasharray={`${baseArc} ${circ - baseArc}`}
        strokeDashoffset={circ / 4}
        strokeLinecap="round"
      />
      <circle
        cx={cx}
        cy={cy}
        r={r}
        fill="none"
        stroke="#14784a"
        strokeWidth="20"
        strokeDasharray={`${bonusArc} ${circ - bonusArc}`}
        strokeDashoffset={circ / 4 - baseArc}
        strokeLinecap="round"
      />
      <circle
        cx={cx}
        cy={cy}
        r={r}
        fill="none"
        stroke="#c0392b"
        strokeWidth="20"
        strokeDasharray={`${penaltyArc} ${circ - penaltyArc}`}
        strokeDashoffset={circ / 4 - baseArc - bonusArc}
        strokeLinecap="round"
      />
      <text
        x={cx}
        y={cy - 6}
        textAnchor="middle"
        fontFamily="'Playfair Display', serif"
        fontSize="28"
        fontWeight="700"
        fill="#111110"
      >
        {total}
      </text>
      <text
        x={cx}
        y={cy + 16}
        textAnchor="middle"
        fontFamily="'DM Sans', sans-serif"
        fontSize="12"
        fill="#6b6860"
      >
        / 100
      </text>
    </svg>
  );
}

function ScorePage({ score }) {
  const [displayScore, setDisplayScore] = useState(0);
  const [barWidths, setBarWidths] = useState({ base: 0, bonus: 0, penalty: 0 });

  useEffect(() => {
    let n = 0;
    const t = setInterval(() => {
      n += 3;
      if (n >= score.total) {
        setDisplayScore(score.total);
        clearInterval(t);
      } else setDisplayScore(n);
    }, 18);
    return () => clearInterval(t);
  }, []);

  useEffect(() => {
    const timer = setTimeout(() => {
      setBarWidths({
        base: (97 / 100) * 100,
        bonus: (10 / 100) * 100,
        penalty: (7 / 100) * 100,
      });
    }, 300);
    return () => clearTimeout(timer);
  }, []);

  const breakdown = [
    {
      label: "Base Score",
      value: "+97",
      detail: "Standard completion reward",
      bg: "#f2f1ee",
      color: "#2a2926",
      barColor: "#2a2926",
      barW: barWidths.base,
    },
    {
      label: "Speed Bonus",
      value: "+10",
      detail: "Completed in 3m 42s (< 5 min)",
      bg: "#e8f5ef",
      color: "#14784a",
      barColor: "#14784a",
      barW: barWidths.bonus,
    },
    {
      label: "Efficiency Penalty",
      value: "−7",
      detail: "22 commits (2 over limit of 20)",
      bg: "#fdf0ef",
      color: "#c0392b",
      barColor: "#c0392b",
      barW: barWidths.penalty,
    },
  ];

  const sorted = [...leaderboard].sort((a, b) => b.score - a.score);
  const maxScore = sorted[0].score;

  return (
    <div
      className="page-enter"
      style={{ maxWidth: 1200, margin: "0 auto", padding: "96px 48px 64px" }}
    >
      <div
        className="score-grid"
        style={{ display: "flex", gap: 32, alignItems: "flex-start" }}
      >
        {/* Left */}
        <div style={{ flex: 1 }}>
          {/* Score display */}
          <div
            style={{
              textAlign: "center",
              marginBottom: 40,
              padding: "40px 0",
              background: "#fff",
              borderRadius: 20,
              boxShadow: "0 4px 16px rgba(0,0,0,0.08)",
            }}
          >
            <div
              style={{
                display: "flex",
                alignItems: "baseline",
                justifyContent: "center",
                gap: 4,
              }}
            >
              <span
                style={{
                  fontFamily: "'Playfair Display', serif",
                  fontSize: 88,
                  fontWeight: 700,
                  color: "#111110",
                  lineHeight: 1,
                }}
              >
                {displayScore}
              </span>
              <span
                style={{
                  fontFamily: "'Playfair Display', serif",
                  fontSize: 30,
                  color: "#6b6860",
                }}
              >
                /100
              </span>
            </div>
            <div
              style={{
                fontFamily: "'DM Sans', sans-serif",
                fontSize: 12,
                textTransform: "uppercase",
                letterSpacing: "0.12em",
                color: "#6b6860",
                marginTop: 8,
              }}
            >
              Final Score
            </div>
          </div>

          {/* Breakdown */}
          <div
            style={{
              display: "flex",
              flexDirection: "column",
              gap: 16,
              marginBottom: 32,
            }}
          >
            {breakdown.map(
              ({ label, value, detail, bg, color, barColor, barW }) => (
                <div
                  key={label}
                  style={{
                    background: bg,
                    borderRadius: 12,
                    padding: "20px 24px",
                  }}
                >
                  <div
                    style={{
                      display: "flex",
                      justifyContent: "space-between",
                      alignItems: "center",
                      marginBottom: 10,
                    }}
                  >
                    <div>
                      <div
                        style={{
                          fontFamily: "'DM Sans', sans-serif",
                          fontSize: 15,
                          fontWeight: 600,
                          color: "#111110",
                        }}
                      >
                        {label}
                      </div>
                      <div
                        style={{
                          fontFamily: "'DM Sans', sans-serif",
                          fontSize: 12,
                          color: "#6b6860",
                          marginTop: 2,
                        }}
                      >
                        {detail}
                      </div>
                    </div>
                    <div
                      style={{
                        fontFamily: "'DM Mono', monospace",
                        fontSize: 20,
                        fontWeight: 700,
                        color,
                      }}
                    >
                      {value} pts
                    </div>
                  </div>
                  <div
                    style={{
                      height: 6,
                      background: "rgba(0,0,0,0.08)",
                      borderRadius: 3,
                      overflow: "hidden",
                    }}
                  >
                    <div
                      style={{
                        height: "100%",
                        width: `${barW}%`,
                        background: barColor,
                        borderRadius: 3,
                        transition: "width 1s ease",
                      }}
                    />
                  </div>
                </div>
              ),
            )}
          </div>

          {/* Leaderboard */}
          <div
            style={{
              background: "#fff",
              borderRadius: 16,
              boxShadow: "0 4px 16px rgba(0,0,0,0.08)",
              padding: 28,
            }}
          >
            <div
              style={{
                fontFamily: "'Playfair Display', serif",
                fontSize: 20,
                fontWeight: 700,
                color: "#111110",
                marginBottom: 4,
              }}
            >
              Your Ranking
            </div>
            <div
              style={{
                fontFamily: "'DM Sans', sans-serif",
                fontSize: 13,
                color: "#6b6860",
                marginBottom: 20,
              }}
            >
              Position <strong style={{ color: "#111110" }}>#3</strong> of 24
              teams
            </div>
            {sorted.map((t, i) => (
              <div
                key={t.team}
                style={{
                  display: "flex",
                  alignItems: "center",
                  gap: 12,
                  marginBottom: 12,
                }}
              >
                <div
                  style={{
                    width: 22,
                    fontFamily: "'DM Mono', monospace",
                    fontSize: 12,
                    color: "#6b6860",
                    textAlign: "right",
                  }}
                >
                  #{i + 1}
                </div>
                <div style={{ flex: 1 }}>
                  <div
                    style={{
                      display: "flex",
                      justifyContent: "space-between",
                      marginBottom: 4,
                    }}
                  >
                    <span
                      style={{
                        fontFamily: "'DM Sans', sans-serif",
                        fontSize: 13,
                        fontWeight: t.you ? 700 : 400,
                        color: t.you ? "#1e3a5f" : "#2a2926",
                      }}
                    >
                      {t.team} {t.you && "← You"}
                    </span>
                    <span
                      style={{
                        fontFamily: "'DM Mono', monospace",
                        fontSize: 13,
                        color: "#2a2926",
                      }}
                    >
                      {t.score}
                    </span>
                  </div>
                  <div
                    style={{
                      height: 5,
                      background: "#f2f1ee",
                      borderRadius: 3,
                      overflow: "hidden",
                    }}
                  >
                    <div
                      style={{
                        height: "100%",
                        width: `${(t.score / maxScore) * 100}%`,
                        background: t.you ? "#1e3a5f" : "#c5c3bc",
                        borderRadius: 3,
                        transition: "width 1s ease",
                      }}
                    />
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        {/* Right donut */}
        <div style={{ width: 260, flexShrink: 0 }}>
          <div
            style={{
              background: "#fff",
              borderRadius: 20,
              boxShadow: "0 4px 16px rgba(0,0,0,0.08)",
              padding: 32,
              textAlign: "center",
            }}
          >
            <h3
              style={{
                fontFamily: "'Playfair Display', serif",
                fontSize: 18,
                fontWeight: 700,
                color: "#111110",
                marginBottom: 24,
              }}
            >
              Score Breakdown
            </h3>
            <DonutChart
              base={97}
              bonus={10}
              penalty={-7}
              total={score.total}
            />
            <div
              style={{
                marginTop: 24,
                display: "flex",
                flexDirection: "column",
                gap: 10,
              }}
            >
              {[
                { color: "#1e3a5f", label: "Base Score", val: "97" },
                { color: "#14784a", label: "Speed Bonus", val: "+10" },
                { color: "#c0392b", label: "Penalty", val: "−7" },
              ].map(({ color, label, val }) => (
                <div
                  key={label}
                  style={{ display: "flex", alignItems: "center", gap: 10 }}
                >
                  <div
                    style={{
                      width: 10,
                      height: 10,
                      background: color,
                      borderRadius: "50%",
                      flexShrink: 0,
                    }}
                  />
                  <span
                    style={{
                      fontFamily: "'DM Sans', sans-serif",
                      fontSize: 13,
                      color: "#6b6860",
                      flex: 1,
                      textAlign: "left",
                    }}
                  >
                    {label}
                  </span>
                  <span
                    style={{
                      fontFamily: "'DM Mono', monospace",
                      fontSize: 13,
                      color: "#111110",
                      fontWeight: 600,
                    }}
                  >
                    {val}
                  </span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}

/* ─── PAGE 4: TIMELINE ───────────────────────────────────────────────── */
function TimelinePage({ timeline }) {
  const [expanded, setExpanded] = useState({});
  const cardRefs = useRef([]);

  useEffect(() => {
    const observers = cardRefs.current.map((el, i) => {
      if (!el) return null;
      const obs = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            el.classList.add(i % 2 === 0 ? "slide-left" : "slide-right");
            obs.disconnect();
          }
        },
        { threshold: 0.15 },
      );
      obs.observe(el);
      return obs;
    });
    return () => observers.forEach((o) => o && o.disconnect());
  }, []);

  const toggleExpand = (i) => setExpanded((p) => ({ ...p, [i]: !p[i] }));

  return (
    <div
      className="page-enter"
      style={{ maxWidth: 1200, margin: "0 auto", padding: "96px 48px 64px" }}
    >
      {/* Header */}
      <div
        style={{
          display: "flex",
          alignItems: "center",
          gap: 20,
          marginBottom: 48,
          flexWrap: "wrap",
        }}
      >
        <h1
          style={{
            fontFamily: "'Playfair Display', serif",
            fontSize: 28,
            fontWeight: 700,
            color: "#111110",
          }}
        >
          Pipeline Execution Timeline
        </h1>
        <span
          style={{
            background: "#fdf6e3",
            color: "#c17d11",
            border: "1px solid #c17d11",
            borderRadius: 20,
            padding: "6px 16px",
            fontFamily: "'DM Mono', monospace",
            fontSize: 13,
          }}
        >
          3 / 5 iterations used
        </span>
      </div>

      {/* Timeline */}
      <div style={{ position: "relative", paddingBottom: 40 }}>
        {/* Axis */}
        <div
          style={{
            position: "absolute",
            left: "50%",
            top: 0,
            bottom: 0,
            width: 2,
            background: "#e8e7e3",
            transform: "translateX(-50%)",
          }}
        />

        {timeline.map((run, i) => {
          const isLeft = i % 2 === 0;
          const passed = run.status === "PASSED";
          const isLast = i === timeline.length - 1;
          return (
            <div
              key={i}
              style={{
                position: "relative",
                display: "flex",
                justifyContent: isLeft ? "flex-end" : "flex-start",
                paddingBottom: 48,
              }}
            >
              {/* Axis circle */}
              <div
                style={{
                  position: "absolute",
                  left: "50%",
                  top: 24,
                  transform: "translateX(-50%)",
                  width: 16,
                  height: 16,
                  borderRadius: "50%",
                  background: passed ? "#14784a" : "#c0392b",
                  border: `3px solid ${passed ? "#e8f5ef" : "#fdf0ef"}`,
                  zIndex: 2,
                  animation: isLast ? "dotPulse 1.5s ease infinite" : "none",
                  boxShadow: `0 0 0 4px ${passed ? "rgba(20,120,74,0.15)" : "rgba(192,57,43,0.15)"}`,
                }}
              />

              {/* Card side */}
              <div
                style={{
                  width: "calc(50% - 40px)",
                  [isLeft ? "paddingRight" : "paddingLeft"]: 0,
                }}
              >
                {/* Timestamp chip */}
                <div
                  style={{
                    marginBottom: 8,
                    textAlign: isLeft ? "right" : "left",
                  }}
                >
                  <span
                    style={{
                      fontFamily: "'DM Mono', monospace",
                      fontSize: 12,
                      color: "#6b6860",
                      background: "#f2f1ee",
                      borderRadius: 20,
                      padding: "4px 12px",
                    }}
                  >
                    {run.time} · {run.duration}
                  </span>
                </div>
                {/* Card */}
                <div
                  ref={(el) => (cardRefs.current[i] = el)}
                  className="timeline-card"
                  style={{
                    background: "#fff",
                    borderRadius: 16,
                    padding: 24,
                    boxShadow: "0 4px 16px rgba(0,0,0,0.08)",
                    opacity: 0,
                  }}
                >
                  <div
                    style={{
                      display: "flex",
                      justifyContent: "space-between",
                      alignItems: "center",
                      marginBottom: 16,
                    }}
                  >
                    <span
                      style={{
                        fontFamily: "'Playfair Display', serif",
                        fontSize: 17,
                        fontWeight: 700,
                        color: "#111110",
                      }}
                    >
                      Run #{run.run}
                    </span>
                    <StatusBadge status={run.status} />
                  </div>
                  <div
                    style={{
                      display: "flex",
                      gap: 20,
                      marginBottom: 16,
                      flexWrap: "wrap",
                    }}
                  >
                    {[
                      ["Fixes Applied", run.fixes, "#14784a"],
                      [
                        "Errors Remaining",
                        run.errors,
                        run.errors > 0 ? "#c0392b" : "#14784a",
                      ],
                      ["Duration", run.duration, "#c17d11"],
                    ].map(([label, val, color]) => (
                      <div key={label} style={{ flex: 1, minWidth: 80 }}>
                        <div
                          style={{
                            fontFamily: "'DM Sans', sans-serif",
                            fontSize: 11,
                            color: "#6b6860",
                            marginBottom: 3,
                          }}
                        >
                          {label}
                        </div>
                        <div
                          style={{
                            fontFamily: "'DM Mono', monospace",
                            fontSize: 15,
                            fontWeight: 700,
                            color,
                          }}
                        >
                          {val}
                        </div>
                      </div>
                    ))}
                  </div>

                  {isLast && passed && (
                    <div
                      style={{
                        background: "#e8f5ef",
                        borderRadius: 8,
                        padding: "8px 14px",
                        fontFamily: "'DM Sans', sans-serif",
                        fontSize: 13,
                        fontWeight: 600,
                        color: "#14784a",
                        marginBottom: 12,
                      }}
                    >
                      ✓ Pipeline Stable
                    </div>
                  )}

                  {/* Error List */}
                  {run.errorList && run.errorList.length > 0 && (
                    <div
                      style={{
                        marginBottom: 12,
                        background: "#f8f8f6",
                        borderRadius: 8,
                        padding: 14,
                      }}
                    >
                      <div
                        style={{
                          fontFamily: "'DM Sans', sans-serif",
                          fontSize: 12,
                          fontWeight: 600,
                          color: "#2a2926",
                          marginBottom: 10,
                        }}
                      >
                        Errors Detected ({run.errorList.length})
                      </div>
                      {run.errorList.map((err, ei) => (
                        <div
                          key={ei}
                          style={{
                            display: "flex",
                            alignItems: "center",
                            justifyContent: "space-between",
                            padding: "8px 10px",
                            background: "#fff",
                            borderRadius: 6,
                            marginBottom: 6,
                            gap: 10,
                          }}
                        >
                          <div style={{ flex: 1, minWidth: 0 }}>
                            <div
                              style={{
                                fontFamily: "'DM Mono', monospace",
                                fontSize: 11,
                                color: "#6b6860",
                                overflow: "hidden",
                                textOverflow: "ellipsis",
                                whiteSpace: "nowrap",
                              }}
                            >
                              {err.file}
                            </div>
                            <div
                              style={{
                                fontFamily: "'DM Sans', sans-serif",
                                fontSize: 12,
                                color: "#2a2926",
                                marginTop: 2,
                              }}
                            >
                              {err.error}
                            </div>
                          </div>
                          {err.status === "fixed" ? (
                            <span
                              style={{
                                fontFamily: "'DM Sans', sans-serif",
                                fontSize: 11,
                                fontWeight: 600,
                                color: "#14784a",
                                whiteSpace: "nowrap",
                              }}
                            >
                              ✓ Fixed
                            </span>
                          ) : (
                            <button
                              onClick={() => alert(`Attempting to fix: ${err.error}`)}
                              style={{
                                padding: "4px 12px",
                                background: "#2a2926",
                                color: "#fff",
                                borderRadius: 6,
                                fontFamily: "'DM Sans', sans-serif",
                                fontSize: 11,
                                fontWeight: 500,
                                whiteSpace: "nowrap",
                                transition: "all 0.2s ease",
                              }}
                              onMouseEnter={(e) => {
                                e.currentTarget.style.background = "#111110";
                              }}
                              onMouseLeave={(e) => {
                                e.currentTarget.style.background = "#2a2926";
                              }}
                            >
                              Fix
                            </button>
                          )}
                        </div>
                      ))}
                    </div>
                  )}

                  <button
                    onClick={() => toggleExpand(i)}
                    style={{
                      background: "transparent",
                      border: "1px solid #e8e7e3",
                      borderRadius: 8,
                      padding: "6px 14px",
                      fontFamily: "'DM Sans', sans-serif",
                      fontSize: 12,
                      color: "#6b6860",
                      transition: "all 0.2s ease",
                      width: "100%",
                    }}
                    onMouseEnter={(e) => {
                      e.currentTarget.style.background = "#f2f1ee";
                      e.currentTarget.style.borderColor = "#2a2926";
                      e.currentTarget.style.color = "#2a2926";
                    }}
                    onMouseLeave={(e) => {
                      e.currentTarget.style.background = "transparent";
                      e.currentTarget.style.borderColor = "#e8e7e3";
                      e.currentTarget.style.color = "#6b6860";
                    }}
                  >
                    {expanded[i] ? "▲ Hide Commit Log" : "▼ View Commit Log"}
                  </button>

                  {expanded[i] && (
                    <div
                      style={{
                        marginTop: 12,
                        background: "#f2f1ee",
                        borderRadius: 8,
                        padding: 14,
                        fontFamily: "'DM Mono', monospace",
                        fontSize: 12,
                        color: "#2a2926",
                        lineHeight: 1.8,
                      }}
                    >
                      {run.commits.map((c, ci) => (
                        <div key={ci}>
                          <span style={{ color: "#c5c3bc" }}>$</span> git log:{" "}
                          {c}
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </div>
          );
        })}
      </div>

      {/* Summary stats */}
      <div
        style={{
          display: "flex",
          gap: 24,
          borderTop: "1px solid #e8e7e3",
          paddingTop: 32,
          marginBottom: 32,
          flexWrap: "wrap",
        }}
      >
        {[
          ["Total Duration", "4m 18s"],
          ["Successful on Iteration", "3"],
          ["Commits Made", "22"],
        ].map(([label, val]) => (
          <div
            key={label}
            style={{
              flex: 1,
              minWidth: 160,
              textAlign: "center",
              padding: "20px 16px",
              background: "#fff",
              borderRadius: 12,
              boxShadow: "0 1px 3px rgba(0,0,0,0.06)",
            }}
          >
            <div
              style={{
                fontFamily: "'DM Sans', sans-serif",
                fontSize: 12,
                color: "#6b6860",
                marginBottom: 6,
                textTransform: "uppercase",
                letterSpacing: "0.08em",
              }}
            >
              {label}
            </div>
            <div
              style={{
                fontFamily: "'DM Mono', monospace",
                fontSize: 22,
                fontWeight: 700,
                color: "#111110",
              }}
            >
              {val}
            </div>
          </div>
        ))}
      </div>

      {/* All Fixes Table */}
      <div
        style={{
          background: "#fff",
          borderRadius: 20,
          boxShadow: "0 4px 16px rgba(0,0,0,0.08)",
          overflow: "hidden",
        }}
      >
        <div style={{ padding: "32px 40px 20px" }}>
          <h2
            style={{
              fontFamily: "'Playfair Display', serif",
              fontSize: 24,
              fontWeight: 700,
              color: "#111110",
              marginBottom: 4,
            }}
          >
            All Fixes Applied
          </h2>
          <p
            style={{
              fontFamily: "'DM Sans', sans-serif",
              fontSize: 14,
              color: "#6b6860",
            }}
          >
            Complete list of all fixes across all iterations
          </p>
        </div>
        <div style={{ overflowX: "auto" }}>
          <table>
            <thead>
              <tr style={{ background: "#f2f1ee" }}>
                {["File", "Bug Type", "Line", "Commit Message", "Status"].map(
                  (h) => (
                    <th
                      key={h}
                      style={{
                        fontFamily: "'DM Sans', sans-serif",
                        fontSize: 11,
                        fontWeight: 600,
                        color: "#6b6860",
                        textTransform: "uppercase",
                        letterSpacing: "0.1em",
                        borderBottom: "1px solid #e8e7e3",
                      }}
                    >
                      {h}
                    </th>
                  ),
                )}
              </tr>
            </thead>
            <tbody>
              {mockResults.fixes.map((fix, i) => (
                <tr
                  key={i}
                  style={{
                    borderBottom: "1px solid #f2f1ee",
                    transition: "background 0.15s ease",
                    cursor: "default",
                  }}
                  onMouseEnter={(e) => {
                    e.currentTarget.style.background = "#f8f8f6";
                  }}
                  onMouseLeave={(e) => {
                    e.currentTarget.style.background = "transparent";
                  }}
                >
                  <td
                    style={{
                      fontFamily: "'DM Mono', monospace",
                      fontSize: 12,
                      color: "#6b6860",
                      maxWidth: 180,
                      overflow: "hidden",
                      textOverflow: "ellipsis",
                      whiteSpace: "nowrap",
                    }}
                  >
                    {fix.file}
                  </td>
                  <td>
                    <BugBadge type={fix.bugType} />
                  </td>
                  <td
                    style={{
                      fontFamily: "'DM Mono', monospace",
                      fontSize: 13,
                      color: "#2a2926",
                    }}
                  >
                    {fix.line}
                  </td>
                  <td
                    style={{
                      fontFamily: "'DM Sans', sans-serif",
                      fontSize: 13,
                      fontStyle: "italic",
                      color: "#6b6860",
                      maxWidth: 240,
                      overflow: "hidden",
                      textOverflow: "ellipsis",
                      whiteSpace: "nowrap",
                    }}
                    title={fix.commit}
                  >
                    {fix.commit}
                  </td>
                  <td
                    style={{
                      fontFamily: "'DM Sans', sans-serif",
                      fontSize: 13,
                      fontWeight: 700,
                      color: fix.status === "Fixed" ? "#14784a" : "#c0392b",
                    }}
                  >
                    {fix.status === "Fixed" ? "✓ Fixed" : "✗ Failed"}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
}
